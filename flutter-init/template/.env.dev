# 开发环境配置
# ⚠️ 这是模板,部分 key 是占位符,请改为真实值
#
# ⚠️ 不要在 .env.prod 填入真实生产 key,生产 key 由 CI/CD 注入

API_VERSION=1.0.0-dev

# 三端三套 API key (与后端约定)
# ⚠️ 改为真实值后才能跑通真实接口
API_WEB_KEY=your_web_key_16
API_IOS_KEY=your_ios_key_16
API_ANDROID_KEY=your_android_key_16

# Header 签名 key
API_HEADER_KEY=your_header_key_32_bytes_long_xxx

# 加密图片 key
IMG_KEY=your_img_key_16

# 主接口地址
DEFAULT_SITE_URL=https://api.example.com

# 主线路 (NORMAL_LINES) 和备用线路 (BACKUP_LINES)
# 格式: url1|code1,url2|code2
NORMAL_LINES=https://api.example.com|line1
BACKUP_LINES=https://backup.example.com|line100

DEFAULT_API_CODE=line1
API_PREFIX=/api

# 加密模式: static (后端新规范) / dynamic (yc141 方案)
ENCRYPT_MODE=static

# 静态加密密钥 (32 字节,后端新规范)
# ⚠️ 改为后端给的真实密钥
STATIC_ENCRYPT_KEY=2311b15a4da1c80dc541b99abb622233

# 调试模式: true 时跳过加解密,方便抓包
# static 模式: 加 X-Encrypt: 1 请求头
# ⚠️ 生产环境务必设为 false
DEBUG_ENCRYPT=true
