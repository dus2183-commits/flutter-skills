# fvm — 锁定 Flutter 版本
# .fvmrc 入 git (锁版本号)
# .fvm/flutter_sdk 不入 git (软链接,各人机器路径不同)
# .fvm/versions 不入 git (实际 SDK 文件,大且本地)
.fvm/flutter_sdk
.fvm/versions
.fvm/.fvmrc-cache

